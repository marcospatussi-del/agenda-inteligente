PORT=5000
JWT_SECRET="agenda_inteligente_secret_key_md3_2026"
EMAIL_FROM="Agenda Inteligente <notificacoes@agendainteligente.app>"
CLIENT_URL="http://localhost:3000"

# Supabase PostgreSQL Database URLs
# Pooler connection (Port 6543) used by Prisma application
DATABASE_URL="postgres://postgres.[YOUR-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection (Port 5432) used for Prisma migrations
DIRECT_URL="postgres://postgres.[YOUR-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# Supabase API Credentials
SUPABASE_URL="https://[YOUR-PROJECT-REF].supabase.co"
SUPABASE_ANON_KEY="your-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"
